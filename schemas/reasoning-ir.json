{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reasoning-ir",
  "title": "Reasoning IR",
  "type": "object",
  "required": [
    "observations",
    "hypotheses",
    "contradictions",
    "questions"
  ],
  "properties": {
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "text",
          "provenance"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "provenance": {
            "type": "array"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "text",
          "basis"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "basis": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "contradictions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "a_claim",
          "b_claim"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "a_claim": {
            "type": "string"
          },
          "b_claim": {
            "type": "string"
          },
          "explanation": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "text"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "theme": {
            "type": "string"
          },
          "why_unanswered": {
            "type": "string"
          }
        }
      }
    }
  }
}