{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "entity-ir",
  "title": "Entity IR",
  "type": "object",
  "required": [
    "entities",
    "terms",
    "claims"
  ],
  "properties": {
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "type",
          "span"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "person",
              "system",
              "concept",
              "library",
              "method",
              "metric",
              "event",
              "organization"
            ]
          },
          "span": {
            "type": "object",
            "required": [
              "doc",
              "section"
            ],
            "properties": {
              "doc": {
                "type": "string"
              },
              "section": {
                "type": "string"
              },
              "start": {
                "type": "integer"
              },
              "end": {
                "type": "integer"
              }
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "terms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "doc"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "doc": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "text",
          "doc"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "doc": {
            "type": "string"
          },
          "section": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "entity_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}