{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "semantic-ir",
  "title": "Semantic IR",
  "type": "object",
  "properties": {
    "themes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "member_node_ids"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "member_node_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "embeddings": {
      "type": "object"
    },
    "summaries": {
      "type": "object"
    }
  }
}